{
  "mcpServers": {
    "notion-personal": {
      "url": "https://mcp.notion.com/mcp",
      "auth": "oauth"
    },
    "notion-parloa": {
      "url": "https://mcp.notion.com/mcp",
      "auth": "oauth"
    },
    "datadog-mcp": {
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp",
      "auth": "oauth"
    },
    "miro": {
      "url": "https://mcp.miro.com",
      "auth": "oauth"
    },
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/mcp",
      "auth": "oauth"
    },
    "google-workspace": {
      "command": "sh",
      "args": ["-c", "exec ~/.cache/mcp-gateway/target/release/google-workspace-stdio \"$@\"", "--"]
    },
    "playwright": {
      "command": "sh",
      "args": ["-c", "exec ~/.claude/playwright-mcp.sh \"$@\"", "--"]
    }
  }
}
